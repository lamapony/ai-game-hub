# === Клиентские переменные (Vite, доступны в браузере) ===
VITE_SUPABASE_URL="https://<your-project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<publishable-anon-key>"
VITE_SUPABASE_PROJECT_ID="<your-project-ref>"

# === Серверные переменные (доступны только в server functions / SSR) ===
SUPABASE_URL="https://<your-project-ref>.supabase.co"
SUPABASE_PUBLISHABLE_KEY="<publishable-anon-key>"
# Только для админ-операций (bypass RLS). Никогда не коммитить и не отдавать в браузер.
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"
# Shared secret для POST /api/cleanup и GitHub scheduled cleanup workflow.
CLEANUP_SECRET="<long-random-cleanup-secret>"

# === OpenAI / OpenAI-compatible API (используется в /api/speak, /api/transcribe и играх) ===
OPENAI_API_KEY="<openai-api-key>"
# Необязательно: укажи другой OpenAI-compatible endpoint.
OPENAI_BASE_URL="https://api.openai.com/v1"
# Необязательно: переопределение моделей.
OPENAI_CHAT_MODEL="gpt-4o-mini"
OPENAI_VISION_MODEL="gpt-4o-mini"
OPENAI_TTS_MODEL="gpt-4o-mini-tts"
OPENAI_TRANSCRIBE_MODEL="gpt-4o-mini-transcribe"
# Необязательно: 1-5 попыток для transient AI provider/network errors.
OPENAI_RETRY_ATTEMPTS="3"

# === Park Spirit concierge (лобби Q&A, не realtime voice) ===
# auto предпочитает xAI Responses API, если XAI_API_KEY задан; иначе использует OpenAI-compatible chat.
SPIRIT_PROVIDER="auto"
XAI_CHAT_MODEL="grok-4.3"

# === Realtime voice host (виртуальный ведущий) ===
# auto предпочитает xAI, если XAI_API_KEY задан; иначе использует OpenAI.
VOICE_PROVIDER="auto"
OPENAI_REALTIME_MODEL="gpt-realtime-2"
OPENAI_REALTIME_VOICE="marin"
# Необязательно: нужен только для Grok/xAI Voice Agent API. Consumer Grok subscription не заменяет API key.
XAI_API_KEY=""
XAI_REALTIME_MODEL="grok-voice-latest"
