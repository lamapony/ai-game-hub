# === Клиентские переменные (Vite, доступны в браузере) ===
VITE_SUPABASE_URL="https://<your-project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<publishable-anon-key>"
VITE_SUPABASE_PROJECT_ID="<your-project-ref>"

# === Серверные переменные (доступны только в server functions / SSR) ===
SUPABASE_URL="https://<your-project-ref>.supabase.co"
SUPABASE_PUBLISHABLE_KEY="<publishable-anon-key>"
# Только для админ-операций (bypass RLS). Никогда не коммитить и не отдавать в браузер.
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# === OpenAI / OpenAI-compatible API (используется в /api/speak, /api/transcribe и играх) ===
OPENAI_API_KEY="<openai-api-key>"
# Необязательно: укажи другой OpenAI-compatible endpoint.
OPENAI_BASE_URL="https://api.openai.com/v1"
# Необязательно: переопределение моделей.
OPENAI_CHAT_MODEL="gpt-4o-mini"
OPENAI_VISION_MODEL="gpt-4o-mini"
OPENAI_TTS_MODEL="gpt-4o-mini-tts"
OPENAI_TRANSCRIBE_MODEL="gpt-4o-mini-transcribe"
