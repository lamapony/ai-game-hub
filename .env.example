# === Клиентские переменные (Vite, доступны в браузере) ===
VITE_SUPABASE_URL="https://<your-project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<publishable-anon-key>"
VITE_SUPABASE_PROJECT_ID="<your-project-ref>"

# === Серверные переменные (доступны только в server functions / SSR) ===
SUPABASE_URL="https://<your-project-ref>.supabase.co"
SUPABASE_PUBLISHABLE_KEY="<publishable-anon-key>"
# Только для админ-операций (bypass RLS). Никогда не коммитить и не отдавать в браузер.
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# === Lovable AI Gateway (используется в /api/speak, /api/transcribe и играх) ===
# В Lovable выдаётся автоматически. При локальной разработке — получить ключ
# на https://lovable.dev или заменить вызовы в src/lib/ai-gateway.server.ts
# на прямой OpenAI/Gemini API.
LOVABLE_API_KEY="<lovable-ai-gateway-key>"
